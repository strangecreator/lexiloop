# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
# Production for lexiloop.ru:
# ALLOWED_HOSTS=lexiloop.ru,77.91.69.156,127.0.0.1,localhost
# CSRF_TRUSTED_ORIGINS=https://lexiloop.ru
# Add www.lexiloop.ru only after its DNS record exists.
TIME_ZONE=Europe/Amsterdam

# SQLite remains the development default. PostgreSQL is recommended in production.
# After creating an empty PostgreSQL database, migrate safely with:
# sudo env TARGET_DATABASE_URL='postgresql://lexiloop_db:password@127.0.0.1:5432/lexiloop' scripts/migrate-sqlite-to-postgres.sh
# DATABASE_URL=postgresql://lexiloop_db:password@127.0.0.1:5432/lexiloop
# SQLITE_PATH=/absolute/path/to/db.sqlite3

# Generate once with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Keep this stable after users save provider tokens.
TOKEN_ENCRYPTION_KEY=

# Set to 1 only when router obtains credentials from its own server environment.
ALLOW_SERVER_LLM_TOKENS=0
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=1.0
JUDGE_HEDGE_DELAY_SECONDS=3.0
# Judge calls are short; fail fast instead of holding a worker for minutes.
JUDGE_REQUEST_TIMEOUT_SECONDS=30
JUDGE_TOTAL_DEADLINE_SECONDS=40
# Keep below the gunicorn worker timeout (180 s) so slow providers return a
# clean error instead of a 502.
GENERATION_TOTAL_DEADLINE_SECONDS=170
# Cap for the LLM that picks a card image from a pasted page link.
IMAGE_TOTAL_DEADLINE_SECONDS=40
BULK_ITEM_ATTEMPTS=3
BULK_MAX_ROUNDS=5
BULK_TARGET_SUCCESS_RATIO=0.99
BULK_WORKER_POLL_SECONDS=1.0
BULK_STALE_AFTER_SECONDS=30
BULK_SESSION_TIMEOUT_SECONDS=1860

# Optional attribution headers used for models selected through OpenRouter.
OPENROUTER_HTTP_REFERER=https://lexiloop.ru
OPENROUTER_APP_TITLE=LexiLoop

# Pronunciation: dictionary recordings first, then Microsoft neural TTS.
TTS_VOICE=en-US-AriaNeural
TTS_RATE=-5%
TTS_TIMEOUT_SECONDS=25

SQLITE_BUSY_TIMEOUT_SECONDS=30
